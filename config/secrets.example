# dmit-watch Telegram secrets — EXAMPLE ONLY (no real values here).
#
# Copy this file to the runtime dir and fill it in, then lock it down:
#
#   cp config/secrets.example ~/.dmit-watch/config
#   chmod 600 ~/.dmit-watch/config
#
# Loaded at boot by src/config.js (loadSecrets). The watcher fails fast with a
# clear message if either key is missing. NEVER commit real values to the repo.
#
# TELEGRAM_BOT_TOKEN — from @BotFather
# TELEGRAM_CHAT_ID   — message your bot once, then read result[].message.chat.id from:
#     curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/getUpdates"

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
