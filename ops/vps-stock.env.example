# vps-stock board server — runtime environment (compose `env_file`).
# Copy to vps-stock.env beside the compose file on the box and chmod 600 it.
# The real file never enters the repo; this template ships placeholders only.

# Bearer token for POST /api/push — generate with: openssl rand -hex 32
# The SAME value goes on the watcher host as DMIT_WATCH_PUSH_TOKEN (its
# ~/.dmit-watch/config). Unset/empty → the server fails closed: every push
# is 401'd while reads keep serving.
PUSH_TOKEN=replace-with-openssl-rand-hex-32

# In-container listen port. The compose port map targets 8080 — change both
# together or neither. (The loopback HOST port is VPS_STOCK_PORT, set via
# compose interpolation, not here.)
PORT=8080

# Durable snapshot mirror (+ its .tmp sibling). The compose file mounts the
# box's data/ directory at /data read-write; the snapshot survives redeploys.
SNAPSHOT_FILE=/data/snapshot.json

# Subscriber token encryption key — generate with: openssl rand -hex 32
# AES-256-GCM, 32 bytes hex. Encrypts subscriber webhook bot tokens at rest.
# Unset/empty → subscription routes return 503.
TOKEN_KEY=
