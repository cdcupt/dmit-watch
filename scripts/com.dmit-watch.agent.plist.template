<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd LaunchAgent for dmit-watch (TECH §07: RunAtLoad + KeepAlive).
  This is a TEMPLATE — do not load it directly. Run scripts/install-agent.sh,
  which substitutes the __PLACEHOLDERS__ below and installs it to
  ~/Library/LaunchAgents/com.dmit-watch.agent.plist.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dmit-watch.agent</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__START_SH__</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__REPO_DIR__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <!-- Throttle restarts so a crash-loop does not hammer Cloudflare. -->
  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__NODE_DIR__:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StandardOutPath</key>
  <string>__RUNTIME_DIR__/watch.out.log</string>
  <key>StandardErrorPath</key>
  <string>__RUNTIME_DIR__/watch.err.log</string>
</dict>
</plist>
